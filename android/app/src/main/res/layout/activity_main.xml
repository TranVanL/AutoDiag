<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="VDiag - AIDL Service Test"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_get_vin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get VIN (0xF190)"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/title_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_get_sw_version"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get SW Version (0xF187)"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btn_get_vin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_crash_app"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Self-Kill App (Test Death)"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF5252"
        app:layout_constraintTop_toBottomOf="@id/btn_get_sw_version"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_get_soc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get SOC  (0x0105)"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btn_crash_app"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_get_rpm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get RPM  (0x010C)"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btn_get_soc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_get_dtc_list"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Get DtcList  (0xF191)"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btn_get_rpm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <TextView
        android:id="@+id/result_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Waiting for result..."
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:background="@android:color/darker_gray"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/btn_get_dtc_list"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>